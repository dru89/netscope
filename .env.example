# Apple code signing and notarization credentials
#
# These are used in two places:
# 1. GitHub Actions secrets (for CI releases) — see .github/workflows/release.yml
# 2. Local .env file (for local builds only, not needed if using CI)
#
# DO NOT commit the .env file

APPLE_ID="your-apple-id@example.com"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_TEAM_ID="XXXXXXXXXX"

# GitHub token for publishing releases (local builds only — CI uses GITHUB_TOKEN)
# Create at: https://github.com/settings/tokens
# Requires "repo" scope (or "contents: write" for fine-grained tokens)
GH_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# macOS signing certificate (GitHub Actions only)
# Export your Developer ID certificate as a .p12 file, then base64-encode it:
#   base64 -i certificate.p12 | pbcopy
# Store as the MAC_CERTIFICATE_BASE64 secret in GitHub Actions.
# MAC_CERTIFICATE_BASE64="..."
# MAC_CERTIFICATE_PASSWORD="the-password-you-set-when-exporting"
