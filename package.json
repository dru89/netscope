{
  "name": "har-explorer",
  "version": "1.0.0",
  "description": "A desktop app for viewing and exploring HAR files",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:vite": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.har-explorer.app",
    "productName": "HAR Explorer",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "dir"],
      "fileAssociations": [
        {
          "ext": "har",
          "name": "HAR File",
          "description": "HTTP Archive File",
          "role": "Viewer"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
