{
  "name": "netscope",
  "version": "2.0.2",
  "description": "A desktop app for viewing and exploring HAR files",
  "author": "Drew Hays <drew@hays.fm>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dru89/netscope"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:vite": "tsc && vite build",
    "release": "make release",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "site:dev": "npm run dev --prefix site",
    "site:build": "npm run build --prefix site",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "dotenv": "^17.3.1",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.netscope.app",
    "productName": "Netscope",
    "afterPack": "scripts/afterPack.js",
    "afterSign": "scripts/notarize.js",
    "publish": [
      {
        "provider": "github",
        "owner": "Dru89",
        "repo": "netscope"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": "Developer ID Application",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "fileAssociations": [
        {
          "ext": "har",
          "name": "HAR File",
          "description": "HTTP Archive File",
          "role": "Viewer"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "fileAssociations": [
        {
          "ext": "har",
          "name": "HAR File",
          "description": "HTTP Archive File"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "mimeTypes": [
        "application/json"
      ],
      "fileAssociations": [
        {
          "ext": "har",
          "name": "HAR File",
          "description": "HTTP Archive File",
          "mimeType": "application/json"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
